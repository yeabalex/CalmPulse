# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
# 1. Create a free cluster at https://cloud.mongodb.com
# 2. Database Access → Add user (password auth)
# 3. Network Access → Add IP (0.0.0.0/0 for dev, restrict in production)
# 4. Connect → Drivers → copy the connection string
#
# Example Atlas URI (replace user, password, cluster, and database name):
# MONGODB_URI=mongodb+srv://calmpulse_user:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/calmpulse?retryWrites=true&w=majority
#
# If your URI ends with /?retryWrites=... (no db in path), set MONGODB_DB explicitly:
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/calmpulse?retryWrites=true&w=majority
MONGODB_DB=calmpulse

# Local MongoDB (comment out Atlas vars above and use this instead):
# MONGODB_URI=mongodb://127.0.0.1:27017/calmpulse

# ─── Auth (required in production) ─────────────────────────────────────────────
JWT_SECRET=generate-a-long-random-string-for-production

# Optional: force secure session cookies when not using https locally
# SESSION_COOKIE_SECURE=true

# ─── AI features (optional — fallbacks used when unset) ──────────────────────
GROQ_API_KEY=

# ─── App URL (optional — used for secure cookie detection) ─────────────────────
# NEXT_PUBLIC_APP_URL=https://your-domain.com
